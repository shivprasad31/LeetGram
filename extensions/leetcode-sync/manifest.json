{
  "name": "LeetGram LeetCode Sync",
  "description": "Sync accepted LeetCode submissions into your LeetGram account.",
  "version": "0.1.0",
  "manifest_version": 3,
  "action": {
    "default_title": "LeetGram Sync",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "tabs", "webRequest"],
  "host_permissions": ["https://leetcode.com/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
